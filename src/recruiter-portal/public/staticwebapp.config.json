{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/assets/*", "/*.js", "/*.css", "/*.svg", "/*.png", "/*.ico"]
  },
  "mimeTypes": {
    ".html": "text/html"
  },
  "routes": [
    {
      "route": "/assets/*",
      "headers": {
        "Cache-Control": "max-age=31536000, immutable"
      }
    },
    {
      "route": "/*",
      "headers": {
        "Cache-Control": "no-store"
      }
    }
  ]
}
